# Base44 frontend runtime configuration (required)
VITE_BASE44_APP_ID=your-app-id
VITE_BASE44_BACKEND_URL=https://your-base44-backend.example.com

# Build-time compatibility toggle
# Set to true only if legacy Base44 SDK imports are still used.
BASE44_LEGACY_SDK_IMPORTS=false

# ---------------------------------------------------------------------------
# 8x8 CPaaS phone integration (backend Deno function secrets)
# Only these two SECRETS live in the environment. Set them as backend secrets
# in the Base44 dashboard. They are NOT VITE_* vars and must never reach the
# browser. Everything else (SMS/voice sub-account IDs, region, voice API base,
# main office number, off-duty template) is configured at runtime in
# Admin -> Settings -> 8x8 Phone (stored on AgencySettings).
# ---------------------------------------------------------------------------
EIGHT_X_EIGHT_API_KEY=          # 8x8 Connect API bearer token (used for SMS and Voice)
EIGHT_X_EIGHT_WEBHOOK_SECRET=   # shared secret used to verify inbound 8x8 webhooks
