# Base44 frontend runtime configuration (required)
VITE_BASE44_APP_ID=your-app-id
VITE_BASE44_BACKEND_URL=https://your-base44-backend.example.com

# Build-time compatibility toggle
# Set to true only if legacy Base44 SDK imports are still used.
BASE44_LEGACY_SDK_IMPORTS=false

# ---------------------------------------------------------------------------
# Twilio phone integration (backend Deno function secrets)
#
# EASIEST PATH: leave these blank and set the Account SID + Auth Token in-app at
# Administration -> Super Admin (kdeyarmin@comcast.net). Those credentials are
# stored backend-only (IntegrationSecret entity) and power SMS, voice, and
# webhook verification — no dashboard env needed.
#
# These env vars are also supported and TAKE PRECEDENCE over the in-app values
# when set, for teams that prefer dashboard-managed secrets. They are NOT VITE_*
# vars and must never reach the browser. Note: TWILIO_ACCOUNT_SID and
# TWILIO_AUTH_TOKEN also power fax (TWILIO_FAX_NUMBER). Main office number,
# off-duty template, and messaging settings are configured at runtime in
# Admin -> Super Admin (stored on AgencySettings).
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=             # optional — Twilio Account SID (starts with AC). Overrides the in-app value.
TWILIO_AUTH_TOKEN=              # optional — Twilio Auth Token. Overrides the in-app value.
TWILIO_WEBHOOK_SECRET=          # optional — custom webhook shared-secret test path. Twilio normally verifies
                                #   inbound webhooks with your Auth Token (X-Twilio-Signature HMAC-SHA1).
TWILIO_WEBHOOK_URL=             # optional — exact public URL for Twilio signature verification when the app
                                #   sits behind a proxy that changes the Host header (e.g. https://app.example.com/functions/handleTwilioInboundSms).
FUNCTIONS_BASE_URL=             # optional — base URL like https://<app>/functions used to auto-set Twilio
                                #   StatusCallback / webhook URLs in the admin panel.
TWILIO_WEBHOOK_DEBUG=           # optional — set to 1 to log signature header names and verification results
                                #   (never logs secret values). Turn off after debugging.
