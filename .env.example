# Base44 frontend runtime configuration (required)
VITE_BASE44_APP_ID=your-app-id
VITE_BASE44_BACKEND_URL=https://your-base44-backend.example.com

# Build-time compatibility toggle
# Set to true only if legacy Base44 SDK imports are still used.
BASE44_LEGACY_SDK_IMPORTS=false

# ---------------------------------------------------------------------------
# 8x8 CPaaS phone integration (backend Deno function secrets)
#
# EASIEST PATH: leave these blank and set the single 8x8 API secret in-app at
# Super Admin -> Integrations (kdeyarmin@comcast.net). That secret is stored
# backend-only (IntegrationSecret entity) and powers SMS, voice, and webhook
# verification — no dashboard env needed.
#
# These env vars remain supported and TAKE PRECEDENCE over the in-app value when
# set, for teams that prefer dashboard-managed secrets. They are NOT VITE_* vars
# and must never reach the browser. Sub-account IDs, region, voice API base,
# main office number, and off-duty template are configured at runtime in
# Admin -> Settings -> 8x8 Phone (stored on AgencySettings).
# ---------------------------------------------------------------------------
EIGHT_X_EIGHT_API_KEY=          # optional — 8x8 Connect API bearer token (SMS + Voice). Overrides the in-app secret.
EIGHT_X_EIGHT_WEBHOOK_SECRET=   # optional — webhook signing secret. Falls back to the API secret when unset.
