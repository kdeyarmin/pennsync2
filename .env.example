# Base44 frontend runtime configuration (required)
VITE_BASE44_APP_ID=your-app-id
VITE_BASE44_BACKEND_URL=https://your-base44-backend.example.com

# Build-time compatibility toggle
# Set to true only if legacy Base44 SDK imports are still used.
BASE44_LEGACY_SDK_IMPORTS=false

# ---------------------------------------------------------------------------
# 8x8 CPaaS phone integration (backend Deno function secrets)
# Set these as backend secrets in the Base44 dashboard. They are NOT VITE_*
# vars and must never be exposed to the browser. Sub-account IDs, region, and
# the main office number are preferably configured at runtime in the admin
# Phone settings (AgencySettings); the values below act as fallbacks.
# ---------------------------------------------------------------------------
EIGHT_X_EIGHT_SMS_API_KEY=
EIGHT_X_EIGHT_SMS_SUBACCOUNT_ID=
EIGHT_X_EIGHT_VOICE_API_KEY=
EIGHT_X_EIGHT_VOICE_SUBACCOUNT_ID=
EIGHT_X_EIGHT_VOICE_API_BASE=https://voice.wavecell.com/api/v1
EIGHT_X_EIGHT_REGION=us
EIGHT_X_EIGHT_WEBHOOK_SECRET=
EIGHT_X_EIGHT_MAIN_OFFICE_NUMBER=+1XXXXXXXXXX
